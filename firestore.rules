rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isManager() {
      return isAuthenticated() && (getRole() == 'manager' || getRole() == 'admin');
    }

    function isAssistant() {
      return isAuthenticated() && (getRole() == 'assistant' || getRole() == 'manager' || getRole() == 'admin');
    }

    // Rules for 'users' collection
    match /users/{userId} {
      // Any authenticated user can read their own profile, only admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Users can create their own profile upon first login
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Only admins can update roles or delete users
      allow update, delete: if isAdmin();
    }

    // Rules for data collections: patients, medicines, and deliveries
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      
      // Filter by collection name for specific role-based write permissions
      allow create: if isAuthenticated() && isAssistant() && 
        (collection == 'patients' || collection == 'medicines' || collection == 'deliveries');
      
      allow update: if isAuthenticated() && isManager() && 
        (collection == 'patients' || collection == 'medicines' || collection == 'deliveries');
      
      allow delete: if isAuthenticated() && isManager() && 
        (collection == 'patients' || collection == 'medicines' || collection == 'deliveries');
    }
  }
}
